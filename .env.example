 OPENROUTER_API_KEY=your-openrouter-api-key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key     # backend only, never expose to client
SUPABASE_JWT_SECRET=your-jwt-secret                  # from Supabase -> Settings -> API

# OpenCode Providers
# OPENCODE_GO_API_KEY=your-opencode-go-key
# OPENCODE_GO_BASE_URL=https://api.opencode.ai/v1
# OPENCODE_ZEN_API_KEY=your-opencode-zen-key
# OPENCODE_ZEN_BASE_URL=https://api.opencode.ai/v1

# Optional generic fallbacks:
# LLM_API_KEY=your-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEFAULT_MODEL=meta-llama/llama-3-70b-instruct
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# FASTAPI_CORS_ORIGINS can be comma-separated or a JSON array string.
# FASTAPI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://layman.vercel.app
# NEXTAUTH_URL=https://layman.vercel.app
# NEXT_PUBLIC_APP_URL=https://layman.vercel.app
